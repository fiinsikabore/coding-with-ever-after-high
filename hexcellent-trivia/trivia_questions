def ask_trivia_question(question_data):
    print("\n" + question_data["question"])
    for key, text in question_data["choices"].items():
        print(f"  {key}) {text}")

    answer = input("Your answer: ").lower().strip()
    while answer not in question_data["choices"]:
        answer = input("Please choose a valid option: ").lower().strip()

    if answer == question_data["correct"]:
        print("Correct!")
        return True
    else:
        correct_text = question_data["choices"][question_data["correct"]]
        print(f"Not quite - the correct answer was: {correct_text}")
        return False


def run_trivia(trivia_questions):
    score = 0

    for i, question_data in enumerate(trivia_questions, start=1):
        print(f"\n--- Question {i} of {len(trivia_questions)} ---")
        if ask_trivia_question(question_data):
            score += 1

    return score

def get_final_message(score, total):
    percent = round((score / total) * 100)

    if percent == 100:
        return "Perfect score! You're basically Headmaster Grimm's star pupil!"
    elif percent >= 70:
        return "Hexcellent job! You really know your Ever After High."
    elif percent >= 40:
        return "Not bad! A bit more studying in the Mirror Classroom couldn't hurt."
    else:
        return "Time to hit the books at the Book End Bookstore!"

