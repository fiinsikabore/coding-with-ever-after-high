    print("=== Hexcellent Trivia Game ===")
    print("Answer the questions below to test your Ever After High knowledge!\n")

    score = run_trivia(trivia_questions)
    total = len(trivia_questions)
    message = get_final_message(score, total)

    print(f"\n=== Results ===")
    print(f"You scored {score} out of {total}!")
    print(message)

